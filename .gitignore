# ===============================
# MyProject Git Ignore Rules
# Optimized for Termux + GitHub Pages
# ===============================

# ----- System Files -----
.DS_Store
Thumbs.db
*.tmp
*.swp

# ----- Logs (local only) -----
logs/
*.log

# ----- Termux / Linux runtime files -----
*.pid
*.lock

# ----- Node / Package managers -----
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----- Python -----
__pycache__/
*.pyc
*.pyo

# ----- Build outputs -----
dist/
build/
.tmp/

# ----- Environment files -----
.env
.env.local
.env.*

# ----- Editor files -----
.vscode/
.idea/

# ----- OS generated -----
*.bak
*.old

# ----- Cache -----
.cache/
