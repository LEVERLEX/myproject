{
  "project": {
    "dir": "~/myproject",
    "logfile": "autopush.log",
    "lockfile": "autopush.lock",
    "version_file": "VERSION",
    "commits_file": "COMMITS.md",
    "changelog_file": "CHANGELOG.md",
    "branch": "main",
    "remote": "origin"
  },
  "colors": {
    "green": "\u001b[32m",
    "red": "\u001b[31m",
    "yellow": "\u001b[33m",
    "blue": "\u001b[34m",
    "reset": "\u001b[0m"
  },
  "messages": {
    "autopush_running": "⚠ Autopush already running",
    "not_git_repo": "Not a git repository",
    "no_changes": "No changes detected",
    "changes_detected": "Changes detected",
    "version_updated": "Version updated → ",
    "push_success": "Push successful",
    "push_failed": "Push failed",
    "automation_complete": "Automation cycle complete"
  },
  "commit": {
    "auto_prefix": "auto: system update",
    "version_prefix": "chore: bump version to v",
    "commits_log_prefix": "chore: update commits log",
    "changelog_prefix": "docs: update changelog"
  },
  "versioning": {
    "enabled": true,
    "bump_type": "patch"
  },
  "git": {
    "pull_rebase": true,
    "fetch_remote": true,
    "push_remote": true,
    "commit_log_count": 10
  },
  "lock_system": {
    "enabled": true
  },
  "logging": {
    "enabled": true,
    "log_status": true
  }
}